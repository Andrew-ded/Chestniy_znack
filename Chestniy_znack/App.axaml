<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Chestniy_znack"
             x:Class="Chestniy_znack.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppChromeBackgroundBrush" Color="#191919" Opacity="0.8" />
          <SolidColorBrush x:Key="AppShellPaneBackgroundBrush" Color="#191919" Opacity="0.8" />
          <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#171717" />
          <SolidColorBrush x:Key="AppShellBorderBrush" Color="#1E355B" />
          <SolidColorBrush x:Key="AppContentBorderBrush" Color="#313131" />
          <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#313F59" />
          <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#242424" />
          <SolidColorBrush x:Key="AppPanelAltBackgroundBrush" Color="#1D1D1D" />
          <SolidColorBrush x:Key="AppPanelInnerBackgroundBrush" Color="#1B1B1B" />
          <SolidColorBrush x:Key="AppItemBackgroundBrush" Color="#252525" />
          <SolidColorBrush x:Key="AppTextboxBackgroundBrush" Color="#2B2B2B" />
          <SolidColorBrush x:Key="AppTextboxForegroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="AppTitleBrush" Color="#F3F6FF" />
          <SolidColorBrush x:Key="AppBodyBrush" Color="#9BA8BF" />
          <SolidColorBrush x:Key="AppLabelBrush" Color="#DDE6FB" />
          <SolidColorBrush x:Key="AppAccentBrush" Color="#2D62F0" />
          <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#3C6DF1" />
          <SolidColorBrush x:Key="AppInputBorderBrush" Color="#2C466F" />
          <SolidColorBrush x:Key="AppButtonSecondaryBackgroundBrush" Color="#303030" />
          <SolidColorBrush x:Key="AppButtonSecondaryHoverBackgroundBrush" Color="#3A3A3A" />
          <SolidColorBrush x:Key="AppWindowButtonBackgroundBrush" Color="#2A2A2A" />
          <SolidColorBrush x:Key="AppWindowButtonHoverBackgroundBrush" Color="#373737" />
          <SolidColorBrush x:Key="AppWindowButtonForegroundBrush" Color="#E4E4E4" />
          <SolidColorBrush x:Key="AppCloseHoverBrush" Color="#5B2530" />
          <SolidColorBrush x:Key="AppNavHoverBrush" Color="#232323" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppChromeBackgroundBrush" Color="#F4F6FB" Opacity="0.98" />
          <SolidColorBrush x:Key="AppShellPaneBackgroundBrush" Color="#DCE5F3" Opacity="1" />
          <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="AppShellBorderBrush" Color="#CCD7EA" />
          <SolidColorBrush x:Key="AppContentBorderBrush" Color="#C8D3E3" />
          <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#C7D3E4" />
          <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#E7EDF7" />
          <SolidColorBrush x:Key="AppPanelAltBackgroundBrush" Color="#DDE6F3" />
          <SolidColorBrush x:Key="AppPanelInnerBackgroundBrush" Color="#D8E2F0" />
          <SolidColorBrush x:Key="AppItemBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="AppTextboxBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="AppTextboxForegroundBrush" Color="#1D2A3B" />
          <SolidColorBrush x:Key="AppTitleBrush" Color="#0F1728" />
          <SolidColorBrush x:Key="AppBodyBrush" Color="#334155" />
          <SolidColorBrush x:Key="AppLabelBrush" Color="#1E293B" />
          <SolidColorBrush x:Key="AppAccentBrush" Color="#2D62F0" />
          <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#2155DE" />
          <SolidColorBrush x:Key="AppInputBorderBrush" Color="#B5C4DD" />
          <SolidColorBrush x:Key="AppButtonSecondaryBackgroundBrush" Color="#D9E3F2" />
          <SolidColorBrush x:Key="AppButtonSecondaryHoverBackgroundBrush" Color="#CCD9EC" />
          <SolidColorBrush x:Key="AppWindowButtonBackgroundBrush" Color="#D8E2F1" />
          <SolidColorBrush x:Key="AppWindowButtonHoverBackgroundBrush" Color="#C9D7EA" />
          <SolidColorBrush x:Key="AppWindowButtonForegroundBrush" Color="#223149" />
          <SolidColorBrush x:Key="AppCloseHoverBrush" Color="#E9C9CF" />
          <SolidColorBrush x:Key="AppNavHoverBrush" Color="#D4DFF0" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Chestniy_znack/Styles/AppStyles.axaml" />
  </Application.Styles>
</Application>
