<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Chestniy_znack.ViewModels"
             x:Class="Chestniy_znack.Views.Pages.BindingsPage"
             x:DataType="vm:BindingsPageViewModel">
  <Grid Width="860"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Margin="0,10,0,0"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="12">
    <TextBlock Text="Примеры связки View и ViewModel" Classes="page-title" />
    <TextBlock Grid.Row="1"
               Text="Эта страница показывает, как в шаблоне разложены экраны и их модели представления."
               Classes="section-text"
               TextWrapping="Wrap" />

    <ItemsControl Grid.Row="2" ItemsSource="{Binding Mappings}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ViewBindingItemViewModel">
          <Border Classes="page-card" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="14">
              <TextBlock Text="{Binding ViewPath}" Foreground="#F3F6FF" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="↔" Foreground="#2D62F0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding ViewModelPath}" Foreground="#9BA8BF" VerticalAlignment="Center" />
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</UserControl>
