<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Chestniy_znack.ViewModels"
        xmlns:components="using:Chestniy_znack.Views.Components"
        xmlns:pages="using:Chestniy_znack.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Chestniy_znack.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Честный знак"
        Width="1380"
        Height="840"
        MinWidth="980"
        MinHeight="700"
        TransparencyLevelHint="Mica, AcrylicBlur"
        TransparencyBackgroundFallback="#191919"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        x:Name="MainWindowRoot">
  <Window.Background>
    <DynamicResource ResourceKey="AppChromeBackgroundBrush" />
  </Window.Background>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Border BorderBrush="{DynamicResource AppShellBorderBrush}" BorderThickness="1">
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
      <components:AppHeader Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" />

      <Grid Grid.Row="1"
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            Margin="0,8,0,0">
        <Grid.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Grid.Transitions>

        <StackPanel Spacing="4">
          <Button Classes="nav-button" Command="{Binding GoToStartPageCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="01" Foreground="{DynamicResource AppBodyBrush}" />
              <TextBlock Text="Старт" Foreground="{DynamicResource AppTitleBrush}" />
            </StackPanel>
          </Button>

          <Button Classes="nav-button" Command="{Binding GoToWorkspacePageCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="02" Foreground="{DynamicResource AppBodyBrush}" />
              <TextBlock Text="Заполнение" Foreground="{DynamicResource AppTitleBrush}" />
            </StackPanel>
          </Button>

          <Button Classes="nav-button secondary-button"
                  Command="{Binding ToggleThemeCommand}"
                  Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="☼" Foreground="{DynamicResource AppBodyBrush}" />
              <TextBlock Text="{Binding ThemeButtonText}" Foreground="{DynamicResource AppTitleBrush}" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Grid.Column="1"
              Padding="12"
              Background="{DynamicResource AppContentBackgroundBrush}"
              BorderBrush="{DynamicResource AppContentBorderBrush}"
              CornerRadius="15,0,0,15">
        <Grid>
          <pages:StartPage DataContext="{ReflectionBinding DataContext.StartPageViewModel, ElementName=MainWindowRoot}"
                           IsVisible="{ReflectionBinding DataContext.IsStartPage, ElementName=MainWindowRoot}" />
          <pages:WorkspacePage DataContext="{ReflectionBinding DataContext.WorkspacePageViewModel, ElementName=MainWindowRoot}"
                               IsVisible="{ReflectionBinding DataContext.IsWorkspacePage, ElementName=MainWindowRoot}" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
